# ============================================================
# Code Review Agent 환경변수 설정
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
# ============================================================

# --- GitHub 연동 ---
# Webhook secret: GitHub 웹훅 설정 시 입력한 시크릿 (HMAC-SHA256 서명 검증용)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Personal Access Token: repo 스코프 필요 (diff 조회 + 코멘트 작성)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# --- LLM ---
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# --- 리뷰 대상 필터 ---
# 쉼표로 구분, 예: .py,.js,.ts
TARGET_EXTENSIONS=.py

# 파일당 최대 diff 줄 수 (초과 시 잘림)
MAX_DIFF_LINES=500

# --- Push 이벤트 설정 ---
# push 이벤트 시 리뷰 대상 브랜치 (쉼표 구분)
# 예: main,develop → main 또는 develop 브랜치에 push된 경우만 리뷰
TARGET_BRANCHES=main,develop

# --- 이메일 (SMTP) ---
# Gmail 사용 시 '앱 비밀번호' 발급 필요 (2FA 활성화 상태)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 수신자 목록 (쉼표 구분)
MAIL_RECIPIENTS=team-lead@company.com,dev@company.com

# --- 리포트 ---
REPORT_OUTPUT_DIR=/tmp/reports

LOG_LEVEL=INFO
